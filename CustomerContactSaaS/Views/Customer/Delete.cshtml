@model CustomerContactSaaS.Models.Customer

<h2>Xóa Khách Hàng</h2>
<h3 class="text-danger">Bạn có chắc chắn muốn xóa khách hàng này không?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Họ và Tên</dt>
        <dd class="col-sm-9">@Model.FullName</dd>
        
        <dt class="col-sm-3">Số điện thoại</dt>
        <dd class="col-sm-9">@Model.PhoneNumber</dd>
        
        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.EmailAddress</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Xóa vĩnh viễn" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Hủy bỏ</a>
    </form>
</div>